# BenefitNavigator Malaysia — environment template.
# Copy to .env and fill secrets at runtime. NEVER commit .env.

# --- Azure OpenAI (Foundry resource, Sweden Central) ---
AZURE_OPENAI_ENDPOINT=https://benefitnav-ai-sc-79c45.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# Fetch the key at runtime (do NOT hardcode):
#   az cognitiveservices account keys list -g rg-benefitnav-my -n benefitnav-ai-sc-79c45 --query key1 -o tsv
AZURE_OPENAI_API_KEY=

# --- Azure AI Search (Basic, Sweden Central) ---
AZURE_SEARCH_ENDPOINT=https://benefitnav-search-79c45.search.windows.net
AZURE_SEARCH_INDEX=benefitnav-corpus
AZURE_SEARCH_KNOWLEDGE_AGENT=benefitnav-agent
# Fetch admin key at runtime (do NOT hardcode):
#   az search admin-key show -g rg-benefitnav-my --service-name benefitnav-search-79c45 --query primaryKey -o tsv
AZURE_SEARCH_API_KEY=

# --- Azure Blob Storage (corpus) ---
AZURE_STORAGE_ACCOUNT=benefitnavstore79c45
AZURE_STORAGE_CONTAINER=corpus
# Fetch key at runtime:
#   az storage account keys list -g rg-benefitnav-my -n benefitnavstore79c45 --query "[0].value" -o tsv
AZURE_STORAGE_KEY=
