# Secrets — keys are fetched at runtime via the az CLI, never committed
.env
*.key

# Python
.venv/
.venv-*/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Node
node_modules/
dist/
.next/

# OS
.DS_Store

# Local Azure artifacts
*.local.json

# Browser / test temp artifacts
.playwright-mcp/
*-snapshot.md

# Logs
*.log

# Local scratch — UI previews, design notes, internal planning kept out of the tree
web/_preview_*.html
CONTROLLER-DESIGN.md
DEMO.md
docs/superpowers/

# Office temp lock files (created while a deck is open)
~$*

# Embedded skill clone (its own git repo — not part of this project)
excalidraw-diagram-skill/

# Deck build workspace + internal scripts — the exported .pptx is what's committed
docs/deck/
docs/DEMO-VIDEO-SCRIPT.md

# Diagram sources kept local — only the exported PNGs are committed to docs/diagrams/
docs/diagrams/*.excalidraw
docs/diagrams/build_foundry_diagram.py
